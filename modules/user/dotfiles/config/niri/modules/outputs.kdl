// https://yalter.github.io/niri/Configuration:-Outputs

// Desktop
output "HDMI-A-1" {
  mode "1920x1080@75.000"
  variable-refresh-rate
  scale 1.0

  hot-corners {
    // off
    // top-left
    // top-right
    // bottom-left
    bottom-right
  }
}

// Laptop
output "eDP-1" {
  mode "1920x1080@60.001"
  scale 1.0

  hot-corners {
    // off
    // top-left
    // top-right
    // bottom-left
    bottom-right
  }
}
